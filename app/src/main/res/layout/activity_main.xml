<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F7FA">

     <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Contador de Passos"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1F2937"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/inputMeta"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Digite sua meta diária"
        android:inputType="number"
        android:background="@android:drawable/edit_text"
        android:padding="12dp"/>

    <Button
        android:id="@+id/btnSalvarMeta"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Salvar Meta"
        android:layout_marginTop="12dp"
        android:backgroundTint="#4F46E5"
        android:textColor="#FFFFFF"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="20dp"
        android:layout_marginTop="24dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/txtMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Meta: -"
            android:textSize="16sp"
            android:textColor="#6B7280"/>

        <TextView
            android:id="@+id/txtRestante"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Faltam: -"
            android:textSize="16sp"
            android:textColor="#6B7280"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/txtPassos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:gravity="center"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:textColor="#10B981"/>

    </LinearLayout>

</LinearLayout>